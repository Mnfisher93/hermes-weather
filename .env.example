# ══════════════════════════════════════════════════════════════
# HERMES — Polymarket Weather Arbitrage Agent
# Copy to .env and fill from your sentinel env
# ══════════════════════════════════════════════════════════════

# ── Polymarket (grab from hyper-sentinel .env) ────────────────
POLYMARKET_PRIVATE_KEY=0xYourPrivateKey
POLYMARKET_FUNDER=0xYourFunderAddress   # omit if standard EOA, set if proxy wallet

# ── Chain ─────────────────────────────────────────────────────
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com

# ── Claude ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY   # same as LLM_API_KEY in sentinel

# ── Risk Limits ───────────────────────────────────────────────
MAX_BET_USD=50
MAX_EXPOSURE_USD=200
MIN_EDGE=0.05
KELLY_FRACTION=0.25

# ── Mode ──────────────────────────────────────────────────────
SIM_MODE=true   # flip to false when ready to go live
